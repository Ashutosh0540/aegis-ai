{
  "title": "AegisAI — API Overview",
  "uid": "aegis-ai-overview",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Request rate by path (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (path) (rate(http_requests_total[5m]))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error rate (5xx) by path",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (path) (rate(http_requests_total{status_code=~\"5..\"}[5m]))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "p95 request latency by path",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (path, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total requests (last 5m)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum(increase(http_requests_total[5m]))" }
      ]
    }
  ]
}
