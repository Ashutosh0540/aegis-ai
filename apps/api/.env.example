ENVIRONMENT=development
DEBUG=true

JWT_SECRET_KEY=change-me-to-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

DATABASE_URL=postgresql+asyncpg://aegis:aegis@postgres:5432/aegis_ai
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

CORS_ORIGINS=["http://localhost:3000"]

OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

STORAGE_ENDPOINT_URL=http://minio:9000
STORAGE_ACCESS_KEY=aegis_minio
STORAGE_SECRET_KEY=aegis_minio_secret
STORAGE_BUCKET=aegis-documents
STORAGE_REGION=us-east-1
STORAGE_USE_SSL=false

MAX_UPLOAD_SIZE_BYTES=26214400

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

FAISS_INDEX_DIR=/app/data/faiss_indices
PINECONE_API_KEY=
PINECONE_INDEX_NAME=aegis-ai-documents

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

RAG_TOP_K=5
RAG_HISTORY_MESSAGE_LIMIT=10

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@aegis-ai.local
SMTP_USE_TLS=true
FRONTEND_BASE_URL=http://localhost:3000

N8N_BASE_URL=http://n8n:5678
N8N_WEBHOOK_TIMEOUT_SECONDS=10

# LangSmith tracing (off by default; no network call unless enabled)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=aegis-ai
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Placeholder flat-rate AI cost estimate (see analytics module docstring)
AI_COST_PER_AGENT_RUN_USD=0.01
